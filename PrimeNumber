import math

def is_prime(num):
    if num <= 1 :
        return False 
    
    for i in range(2,int(math.sqrt(num))+1 ):
        if num % i == 0: 
            return False
    return True
    
n = int(input("Enter the Number: "))
    
if is_prime(n):
    print(n, "is a prime number")
else:
    print(n, "is NOT a prime number")


